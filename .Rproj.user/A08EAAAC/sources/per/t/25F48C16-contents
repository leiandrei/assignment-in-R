# scatterplot function

plot_scatter <- function(data, x, y, c, s) {
  ggplot(data, aes({{x}}, {{y}}, color={{c}}, size={{s}})) +
    geom_point() + scale_x_log10()
}

plot_faceting <- function(data, x, y) {
  ggplot(data, aes({{x}}, {{y}})) + 
    geom_point() + scale_x_log10() +
    facet_wrap(~ continent)
}

plot_scatter(gapminder_1952, gdpPercap, lifeExp, continent, pop)
plot_faceting(gapminder_1952, gdpPercap, lifeExp)


# Data Analysis by Summarization using summarize verb
gapminder %>%
  filter(year == 2007) %>%
  summarize(meanLifeExp = mean(lifeExp), totalPop = sum(pop))

# Data Analysis by grouping by
gapminder %>%
  group_by(year) %>%
  summarize(meanLifeExp = mean(lifeExp), totalPop = sum(pop))

gapminder %>% 
  filter(year == 2007) %>%
  group_by(continent) %>%
  summarize(meanLifeExp = mean(lifeExp), totalPop = sum(pop))

gapminder %>%
  group_by(year, continent) %>%
  summarize(meanLifeExp = mean(lifeExp), totalPop = sum(pop))

# Data Visualization through summarized data
by_year_continent <- gapminder %>%
  group_by(year, continent) %>%
  summarize(totalPop = sum(pop), meanLifeExp = mean(lifeExp))

ggplot(by_year_continent, aes(year, totalPop, color=continent)) + 
  geom_line() + expand_limits(y=0)

by_continent_2007 <- gapminder %>%
  filter(year == 2007) %>%
  group_by(continent) %>%
  summarize(medianLifeExp = median(lifeExp), medianGdpPercap = median(gdpPercap))

ggplot(by_continent_2007, aes(medianGdpPercap, medianLifeExp, color=continent)) + 
  geom_point() + expand_limits(y=0)

by_year_all <- gapminder %>%
  group_by(year, continent) %>%
  summarize(medianGdpPercap = median(gdpPercap))

ggplot(by_year_all, aes(year, medianGdpPercap, color=continent)) +
  geom_line() + expand_limits(y=0)

by_continent <- gapminder %>%
  filter(year == 2007) %>%
  group_by(continent) %>%
