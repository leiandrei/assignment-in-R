library(gapminder) # load the csv data
library(tidyverse) # library that includes both ggplot & dpylr
library(readxl) # loading excel data

# filtering verb (based on condition)
gapminder %>%
  filter(year == 2007)

# arrange verb (sorting)
gapminder %>%
  arrange(desc(gdpPercap))

# combining the filter and arrange
gapminder %>%
  filter(year == 2007) %>%
  arrange(desc(gdpPercap))

# mutate verb (for data processing)
gapminder %>%
  mutate(pop = pop / 1000000)

# mutate to add a new variable
gapminder %>%
  mutate(gdp = gdpPercap * pop)

# combination of all verb for robust data analysis
gapminder %>%
  mutate(gdp = gdpPercap * pop) %>%
  filter(year == 2007) %>%
  arrange(desc(gdp))

gapminder %>%
  mutate(lifeExpMonth = 12 * lifeExp)


